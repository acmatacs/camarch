// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGIN_FAILED
  LOGOUT
  EXPORT
}

model AuditLog {
  id          String     @id @default(uuid())
  action      ActionType
  entityType  String?    // e.g. "Temple", "Province" — null for auth actions
  entityId    String?    // String ID of the affected record
  actorId     String?    // User ID — nullable for unauthenticated attempts
  actorEmail  String?    // Captured email, survives user deletion
  oldValues   Json?      // Record state BEFORE mutation (UPDATE / DELETE)
  newValues   Json?      // Record state AFTER mutation (CREATE / UPDATE)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  // NO @updatedAt — audit logs are immutable append-only records
  @@index([createdAt(sort: Desc)])
  @@index([actorEmail])
  @@index([entityType, entityId])
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  name         String?
  isActive     Boolean    @default(true)
  roleId       Int?
  role         AdminRole? @relation(fields: [roleId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AdminRole {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          Int              @id @default(autoincrement())
  action      String           @unique  // e.g. "temples:write", "users:manage"
  module      String           // e.g. "temples", "users", "roles", "audit"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         AdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Province {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  temples     Temple[]
}

model King {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  reignStart  Int?
  reignEnd    Int?
  description String?
  temples     Temple[]
}

model Style {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  period  String?
  temples Temple[]
}

model Era {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  temples Temple[]
}

model Temple {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  name           String
  khmerName      String?
  description    String   @db.Text
  history        String?  @db.Text
  latitude       Float
  longitude      Float
  provinceId     Int
  province       Province @relation(fields: [provinceId], references: [id])
  yearBuilt      Int?
  kingId         Int?
  king           King?    @relation(fields: [kingId], references: [id])
  styleId        Int?
  style          Style?   @relation(fields: [styleId], references: [id])
  eraId          Int?
  era            Era?     @relation(fields: [eraId], references: [id])
  religion       String?
  featuredImage  String
  galleryImages  String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

