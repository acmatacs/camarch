# Supabase PostgreSQL connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Direct URL (for Prisma migrations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Next.js Public URL (set for your Vercel deployment)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin JWT secret — generate with: node -e "require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-32-byte-hex-secret-here"

# Admin portal password
ADMIN_PASSWORD="ChangeMe@1234"
